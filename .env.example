# Copia este archivo a "assets/env" y rellena los valores.
# (Se usa assets/env, sin punto inicial: un archivo .env NO se empaqueta en el
#  build web release de Flutter y la app queda en pantalla blanca.)
# SOLO valores PUBLICOS. NUNCA pongas aqui el service_role key.
SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_ANON_KEY=tu-anon-key-publica
